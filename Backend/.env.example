# ============================================================
#  .env  —  ENVIRONMENT VARIABLES (your secret config)
#
#  IMPORTANT RULES:
#  1. NEVER commit this file to GitHub — add it to .gitignore
#  2. Never share these values publicly
#  3. Each line is: KEY=value  (no spaces around the = sign)
# ============================================================

# ----- SERVER -----
# The port your server runs on locally
PORT=5000

# ----- DATABASE (PostgreSQL) -----
# These are the details to connect to your PostgreSQL database.
# Replace the values with your actual PostgreSQL setup.

DB_HOST=localhost       # Where your DB is running (localhost = your own machine)
DB_PORT=5432            # PostgreSQL's default port — don't change unless you changed it during install
DB_NAME=tirelo_classes  # The database name you create in PostgreSQL
DB_USER=postgres        # Your PostgreSQL username (default is usually "postgres")
DB_PASSWORD=yourpassword  # The password you set when installing PostgreSQL

# ----- EMAIL (Gmail SMTP) -----
# We use an app-password (recommended) instead of your normal Gmail password.
#
# Gmail SMTP:
# - Host: smtp.gmail.com
# - Port: 587 (STARTTLS) or 465 (SSL)
#
# Make sure the app password is enabled in your Google account.
TEACHER_EMAIL=tkmaile@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
# Optional "From" header value
# MAIL_FROM="TK Maile <your_gmail@gmail.com>"
